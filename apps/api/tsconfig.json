{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "types": ["bun", "node"],
    "paths": {
      "@/*": ["./src/*"],
      "@workspace/shared/*": ["../../packages/shared/src/*"],
      "@testplatform/core": ["../../packages/core/src/index.ts"],
      "@testplatform/core/*": ["../../packages/core/src/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
